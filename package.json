{
  "name": "session-cache-mcp",
  "version": "0.1.1",
  "description": "Session-scoped MCP server that eliminates redundant file reads across Claude Code subagents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "session-cache-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "hooks",
    "rules"
  ],
  "scripts": {
    "build": "tsc && node scripts/add-shebang.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "session-cache",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
